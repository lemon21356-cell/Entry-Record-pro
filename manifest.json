{
  "manifest_version": 3,
  "name": "엔트리 레코더 최종 수정판",
  "version": "1.4",
  "permissions": ["storage", "activeTab", "downloads"],
  "action": { "default_popup": "popup.html" },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://playentry.org/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["start.png", "stop.png"],
      "matches": ["https://playentry.org/*"]
    }
  ]
}
